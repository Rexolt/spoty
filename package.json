{
  "name": "spoty",
  "version": "3.2.3",
  "description": "Modern Spotlight-like search & launcher app for Windows, Linux and macOS",
  "main": "main.js",
  "homepage": "https://github.com/Rexolt/spoty",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rexolt/spoty.git"
  },
  "author": {
    "name": "Rexolt",
    "email": "c1e3x5eu@anonaddy.me"
  },
  "keywords": [
    "spotlight",
    "launcher",
    "search",
    "electron",
    "desktop"
  ],
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --linux --win --mac"
  },
  "build": {
    "appId": "com.rexolt.spoty",
    "productName": "Spoty",
    "artifactName": "${productName}-${arch}.${ext}",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "build/icons/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm",
        "pacman"
      ],
      "icon": "build/icons",
      "category": "Utility",
      "desktop": {
        "Name": "Spoty",
        "Comment": "Modern Spotlight-like search & launcher",
        "Keywords": "search;launcher;spotlight;lookup;"
      }
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icons/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icons/512x512.png",
      "category": "public.app-category.utilities",
      "identity": null
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${arch}.${ext}",
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },
    "portable": {
      "artifactName": "${productName}-Portable-${arch}.${ext}"
    }
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "fuse.js": "^6.6.2"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.0"
  }
}

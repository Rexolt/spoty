{
  "name": "spoty",
  "version": "3.1.0",
  "description": "Modern Spotlight-like search & launcher app for Windows and Linux",
  "main": "main.js",
  "homepage": "https://github.com/Rexolt/spoty",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rexolt/spoty.git"
  },
  "author": {
    "name": "Rexolt",
    "email": "c1e3x5eu@anonaddy.me"
  },
  "keywords": ["spotlight", "launcher", "search", "electron", "desktop"],
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --linux --win"
  },
  "build": {
    "appId": "com.rexolt.spoty",
    "productName": "Spoty",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "build/icons/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm",
        "pacman"
      ],
      "icon": "build/icons",
      "category": "Utility",
      "desktop": {
        "Name": "Spoty",
        "Comment": "Modern Spotlight-like search & launcher",
        "Keywords": "search;launcher;spotlight;lookup;"
      }
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icons/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  },
  "dependencies": {
    "fuse.js": "^6.6.2"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0"
  }
}
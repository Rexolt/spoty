{
  "name": "spoty",
  "version": "3.2.3",
  "description": "Modern Spotlight-like search & launcher app for Windows, Linux and macOS",
  "main": "dist/main/index.js",
  "homepage": "https://github.com/Rexolt/spoty",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rexolt/spoty.git"
  },
  "author": {
    "name": "Rexolt",
    "email": "c1e3x5eu@anonaddy.me"
  },
  "keywords": [
    "spotlight",
    "launcher",
    "search",
    "electron",
    "desktop"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "esbuild src/renderer/index.ts --bundle --outfile=dist/renderer/index.js --platform=browser --format=iife --target=es2022 --sourcemap",
    "build": "npm run typecheck && npm run build:main && npm run build:renderer",
    "watch:main": "tsc -p tsconfig.main.json --watch",
    "watch:renderer": "esbuild src/renderer/index.ts --bundle --outfile=dist/renderer/index.js --platform=browser --format=iife --target=es2022 --sourcemap --watch",
    "start": "npm run build && electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "build:linux": "npm run build && electron-builder --linux",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:all": "npm run build && electron-builder --linux --win --mac"
  },
  "build": {
    "appId": "com.rexolt.spoty",
    "productName": "Spoty",
    "artifactName": "${productName}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/index.html",
      "src/styles.css",
      "build/icons/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm",
        "pacman"
      ],
      "icon": "build/icons",
      "category": "Utility",
      "desktop": {
        "Name": "Spoty",
        "Comment": "Modern Spotlight-like search & launcher",
        "Keywords": "search;launcher;spotlight;lookup;"
      }
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icons/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icons/512x512.png",
      "category": "public.app-category.utilities",
      "identity": null
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${arch}.${ext}",
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },
    "portable": {
      "artifactName": "${productName}-Portable-${arch}.${ext}"
    }
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "fuse.js": "^6.6.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}

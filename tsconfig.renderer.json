{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ES2022",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": [],
    "rootDir": "./src",
    "outDir": "./dist/renderer-types",
    "noEmit": true,
    "moduleResolution": "Bundler"
  },
  "include": [
    "src/renderer/**/*.ts",
    "src/shared/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/main/**/*"
  ]
}
